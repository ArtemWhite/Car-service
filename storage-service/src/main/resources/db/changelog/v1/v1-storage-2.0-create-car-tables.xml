<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- car_models -->
    <changeSet id="storage-car-1" author="ArtemWhite">
        <createTable tableName="car_models">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="full_name" type="VARCHAR(200)"/>
            <column name="brand_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="generation" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="removed" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_car_model_brand"
                baseTableName="car_models" baseColumnNames="brand_id"
                referencedTableName="car_brands" referencedColumnNames="id"/>
    </changeSet>

    <!-- engines -->
    <changeSet id="storage-car-2" author="ArtemWhite">
        <createTable tableName="engines">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="fuel_type_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="displacement" type="DOUBLE"/>
            <column name="horse_power" type="DOUBLE"/>
            <column name="description" type="VARCHAR(500)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="removed" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_engine_fuel_type"
                baseTableName="engines" baseColumnNames="fuel_type_id"
                referencedTableName="engine_fuel_types" referencedColumnNames="id"/>
    </changeSet>

    <!-- transmissions -->
    <changeSet id="storage-car-3" author="ArtemWhite">
        <createTable tableName="transmissions">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="type_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="gears" type="INT"/>
            <column name="full_name" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="removed" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_transmission_type"
                baseTableName="transmissions" baseColumnNames="type_id"
                referencedTableName="transmission_types" referencedColumnNames="id"/>
    </changeSet>

    <!-- car_configurations — must come before cars (FK dependency) -->
    <changeSet id="storage-car-4" author="ArtemWhite">
        <createTable tableName="car_configurations">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="model_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="base_price" type="DECIMAL(19,2)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="removed" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_configuration_model"
                baseTableName="car_configurations" baseColumnNames="model_id"
                referencedTableName="car_models" referencedColumnNames="id"/>
    </changeSet>

    <!-- components -->
    <changeSet id="storage-car-5" author="ArtemWhite">
        <createTable tableName="components">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="type_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(500)"/>
            <column name="extra_charge" type="DECIMAL(19,2)"/>
            <column name="configuration_id" type="UUID"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="removed" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_component_type"
                baseTableName="components" baseColumnNames="type_id"
                referencedTableName="component_types" referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_component_configuration"
                baseTableName="components" baseColumnNames="configuration_id"
                referencedTableName="car_configurations" referencedColumnNames="id"/>
    </changeSet>

    <!-- component_compatible_models -->
    <changeSet id="storage-car-6" author="ArtemWhite">
        <createTable tableName="component_compatible_models">
            <column name="component_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="model_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_comp_compat_component"
                baseTableName="component_compatible_models" baseColumnNames="component_id"
                referencedTableName="components" referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_comp_compat_model"
                baseTableName="component_compatible_models" baseColumnNames="model_id"
                referencedTableName="car_models" referencedColumnNames="id"/>
    </changeSet>

    <!-- cars — depends on car_configurations (created above), car_models, engines, transmissions, and reference tables from storage-1.0 -->
    <changeSet id="storage-car-7" author="ArtemWhite">
        <createTable tableName="cars">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="brand_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="model_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="body_id" type="UUID"/>
            <column name="color_id" type="UUID"/>
            <column name="drive_type_id" type="UUID"/>
            <column name="engine_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="transmission_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="DECIMAL(19,2)"/>
            <column name="status_id" type="UUID"/>
            <column name="configuration_id" type="UUID"/>
            <column name="car_info" type="VARCHAR(500)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="removed" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_car_brand"
                baseTableName="cars" baseColumnNames="brand_id"
                referencedTableName="car_brands" referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_car_model"
                baseTableName="cars" baseColumnNames="model_id"
                referencedTableName="car_models" referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_car_body"
                baseTableName="cars" baseColumnNames="body_id"
                referencedTableName="car_bodies" referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_car_color"
                baseTableName="cars" baseColumnNames="color_id"
                referencedTableName="car_colors" referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_car_drive_type"
                baseTableName="cars" baseColumnNames="drive_type_id"
                referencedTableName="drive_types" referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_car_engine"
                baseTableName="cars" baseColumnNames="engine_id"
                referencedTableName="engines" referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_car_transmission"
                baseTableName="cars" baseColumnNames="transmission_id"
                referencedTableName="transmissions" referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_car_status"
                baseTableName="cars" baseColumnNames="status_id"
                referencedTableName="car_statuses" referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_car_configuration"
                baseTableName="cars" baseColumnNames="configuration_id"
                referencedTableName="car_configurations" referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
