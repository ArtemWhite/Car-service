    <!-- ===== USER STATUSES ===== -->
    <changeSet id="1000" author="developer">
        <insert tableName="user_statuses">
            <column name="id" valueComputed="gen_random_uuid()"/>
            <column name="name" value="ACTIVE"/>
            <column name="display_name" value="Активен"/>
            <column name="can_authenticate" valueBoolean="true"/>
        </insert>
        <insert tableName="user_statuses">
            <column name="id" valueComputed="gen_random_uuid()"/>
            <column name="name" value="INACTIVE"/>
            <column name="display_name" value="Неактивен"/>
