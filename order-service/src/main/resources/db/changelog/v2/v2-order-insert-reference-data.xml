        </insert>
        <insert tableName="user_statuses">
            <column name="id" valueComputed="gen_random_uuid()"/>
            <column name="name" value="BLOCKED"/>
            <column name="display_name" value="Заблокирован"/>
            <column name="can_authenticate" valueBoolean="false"/>
        </insert>
    </changeSet>

